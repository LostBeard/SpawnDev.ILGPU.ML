@page "/getting-started"

<PageTitle>Getting Started — SpawnDev.ILGPU.ML</PageTitle>

<div class="gs-page">
    <h1 class="gs-title">Getting Started</h1>
    <p class="gs-intro">Add GPU-accelerated ML inference to your .NET app in 5 minutes. Works in Blazor WASM and desktop.</p>

    <div class="gs-steps">
        <div class="gs-step">
            <div class="step-number">1</div>
            <div class="step-content">
                <h3>Install</h3>
                <div class="code-block">
                    <pre><code>dotnet add package SpawnDev.ILGPU.ML</code></pre>
                </div>
            </div>
        </div>

        <div class="gs-step">
            <div class="step-number">2</div>
            <div class="step-content">
                <h3>Create Accelerator</h3>
                <p class="step-desc">Auto-selects the best GPU backend (WebGPU → WebGL → Wasm in browser, CUDA → OpenCL → CPU on desktop).</p>
                <div class="code-block">
<pre><code><span class="kw">using</span> <span class="ns">ILGPU</span>;
<span class="kw">using</span> <span class="ns">SpawnDev.ILGPU</span>;

<span class="kw">var</span> builder = <span class="ty">MLContext</span>.<span class="fn">Create</span>();
<span class="kw">await</span> builder.<span class="fn">AllAcceleratorsAsync</span>();
<span class="kw">using var</span> context = builder.<span class="fn">ToContext</span>();
<span class="kw">using var</span> accelerator = <span class="kw">await</span> context.<span class="fn">CreatePreferredAcceleratorAsync</span>();</code></pre>
                </div>
            </div>
        </div>

        <div class="gs-step">
            <div class="step-number">3</div>
            <div class="step-content">
                <h3>Load a Model</h3>
                <p class="step-desc">Load ONNX models from HuggingFace — cached locally via OPFS. No server needed.</p>
                <div class="code-block">
<pre><code><span class="kw">using</span> <span class="ns">SpawnDev.ILGPU.ML.Hub</span>;

<span class="cm">// Load via ModelHub (preferred — handles caching, progress, CDN)</span>
<span class="kw">using var</span> hub = <span class="kw">new</span> <span class="ty">ModelHub</span>(JS);
<span class="kw">var</span> session = <span class="kw">await</span> <span class="ty">InferenceSession</span>.<span class="fn">CreateFromHuggingFaceAsync</span>(
    accelerator, hub, <span class="ty">ModelHub</span>.<span class="ty">KnownModels</span>.<span class="fn">SqueezeNet</span>);

<span class="cm">// Or direct URL (simpler, still CDN)</span>
<span class="kw">var</span> session = <span class="kw">await</span> <span class="ty">InferenceSession</span>.<span class="fn">CreateFromFileAsync</span>(
    accelerator, httpClient,
    <span class="st">"https://huggingface.co/onnxmodelzoo/squeezenet/resolve/main/squeezenet1.1-7.onnx"</span>);</code></pre>
                </div>
            </div>
        </div>

        <div class="gs-step">
            <div class="step-number">4</div>
            <div class="step-content">
                <h3>Run Inference</h3>
                <p class="step-desc">Create a pipeline, feed it data, get results. All on GPU.</p>
                <div class="code-block">
<pre><code><span class="cm">// Image classification</span>
<span class="kw">var</span> pipeline = <span class="kw">new</span> <span class="ty">ClassificationPipeline</span>(session, accelerator);
<span class="kw">var</span> results = <span class="kw">await</span> pipeline.<span class="fn">ClassifyAsync</span>(rgbaPixels, width, height);

<span class="kw">foreach</span> (<span class="kw">var</span> r <span class="kw">in</span> results)
    Console.<span class="fn">WriteLine</span>(<span class="st">$"</span>{r.Label}: {r.Confidence:P1}<span class="st">"</span>);
<span class="cm">// tiger cat: 52.0%</span>
<span class="cm">// tabby: 39.7%</span></code></pre>
                </div>
            </div>
        </div>

        <div class="gs-step">
            <div class="step-number">5</div>
            <div class="step-content">
                <h3>Inspect Any Model</h3>
                <p class="step-desc">Check if a model is compatible before loading it.</p>
                <div class="code-block">
<pre><code><span class="cm">// Parse and inspect any .onnx file</span>
<span class="kw">var</span> summary = <span class="ty">OnnxLoader</span>.<span class="fn">GetModelSummary</span>(onnxBytes);
<span class="cm">// "Model: squeezenet (opset 9), 66 nodes, 52 weights, 1.2M params"</span>

<span class="cm">// Check operator compatibility</span>
<span class="kw">var</span> compat = <span class="ty">ModelInspectorHelper</span>.<span class="fn">CheckCompatibility</span>(onnxBytes);
<span class="cm">// "Fully compatible (18 operators supported)"</span></code></pre>
                </div>
            </div>
        </div>
    </div>

    <div class="gs-section">
        <h2>Blazor WASM Setup</h2>
        <p>For browser apps, add SpawnDev.BlazorJS and disable trimming:</p>
        <div class="code-block">
<pre><code><span class="cm">&lt;!-- In your .csproj --&gt;</span>
<span class="tag">&lt;PropertyGroup&gt;</span>
    <span class="tag">&lt;PublishTrimmed&gt;</span>false<span class="tag">&lt;/PublishTrimmed&gt;</span>
    <span class="tag">&lt;RunAOTCompilation&gt;</span>false<span class="tag">&lt;/RunAOTCompilation&gt;</span>
<span class="tag">&lt;/PropertyGroup&gt;</span></code></pre>
        </div>
    </div>

    <div class="gs-section">
        <h2>Available Pipelines</h2>
        <div class="pipeline-grid">
            <a href="classify" class="pipeline-card"><span>&#x1F3AF;</span> Image Classification</a>
            <a href="depth" class="pipeline-card"><span>&#x1F30A;</span> Depth Estimation</a>
            <a href="detect" class="pipeline-card"><span>&#x1F50D;</span> Object Detection</a>
            <a href="style" class="pipeline-card"><span>&#x1F3A8;</span> Style Transfer</a>
            <a href="super-res" class="pipeline-card"><span>&#x1F52C;</span> Super Resolution</a>
            <a href="remove-bg" class="pipeline-card"><span>&#x2702;</span> Background Removal</a>
            <a href="pose" class="pipeline-card"><span>&#x1F3CB;</span> Pose Estimation</a>
            <a href="face" class="pipeline-card"><span>&#x1F642;</span> Face Detection</a>
            <a href="clip" class="pipeline-card"><span>&#x1F516;</span> Zero-Shot (CLIP)</a>
            <a href="whisper" class="pipeline-card"><span>&#x1F3A4;</span> Speech to Text</a>
            <a href="text-gen" class="pipeline-card"><span>&#x270D;</span> Text Generation</a>
            <a href="generate" class="pipeline-card"><span>&#x2728;</span> Image Generation</a>
        </div>
    </div>

    <div class="gs-section">
        <h2>Links</h2>
        <div class="link-grid">
