@page "/remove-bg"
@using SpawnDev.BlazorJS
@using SpawnDev.ILGPU.ML
@implements IDisposable

<PageTitle>Background Removal — SpawnDev.ILGPU.ML</PageTitle>

<DemoLayout Title="Background Removal"
            Description="Remove image backgrounds instantly. No server, no upload — your images stay on your device."
            AvailableBackends="@_backends"
            SelectedBackend="@_selectedBackend"
            SelectedBackendChanged="@((v) => _selectedBackend = v)"
            OnBackendChange="@HandleBackendChange"
            InferenceTimeMs="@_inferenceMs"
            IsRunning="@_isRunning"
            ShowModelProgress="true"
            ModelName="RMBG-1.4"
            IsModelLoading="@_isModelLoading"
            IsModelLoaded="@_isModelLoaded"
            ModelProgressPercent="@_modelProgress"
            ModelSizeMB="40">

    @if (_resultImageUrl != null && _imageDataUrl != null)
    {
        <div class="rmbg-output-controls">
            <label class="bg-option-label">Background:</label>
            <button class="bg-option @(_bgMode == "transparent" ? "active" : "")" @onclick='() => _bgMode = "transparent"'>Transparent</button>
            <button class="bg-option @(_bgMode == "white" ? "active" : "")" @onclick='() => _bgMode = "white"'>White</button>
            <button class="bg-option @(_bgMode == "blur" ? "active" : "")" @onclick='() => _bgMode = "blur"'>Blur</button>
        </div>

        <BeforeAfterSlider BeforeImageUrl="@_imageDataUrl"
                           AfterImageUrl="@_resultImageUrl"
                           BeforeLabel="Original"
                           AfterLabel="Removed" />

        <div class="rmbg-actions">
            <button class="download-btn" @onclick="DownloadResult">Download PNG</button>
        </div>
    }
    else
    {
        <ImageDropZone @bind-ImageDataUrl="_imageDataUrl"
                       OnImageLoaded="@HandleImageLoaded"
                       SampleImages="@_samples" />
    }

    @if (_imageDataUrl != null && _resultImageUrl == null && _isModelLoaded && !_isRunning)
    {
        <button class="run-btn" @onclick="RunRemoval">Remove Background</button>
    }

    @if (!_isModelLoaded && !_isModelLoading)
    {
        <div class="model-needed">
            RMBG-1.4 model (~88MB) not yet deployed. Background removal will be enabled once the model is available.
        </div>
    }

    <PrivacyBadge />

</DemoLayout>

<style>
    .rmbg-output-controls {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        margin-bottom: 1rem;
    }

    .bg-option-label {
        color: #64748b;
        font-size: 0.85rem;
        margin-right: 0.25rem;
    }

    .bg-option {
        padding: 0.3rem 0.7rem;
        border-radius: 6px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        background: rgba(255, 255, 255, 0.04);
        color: #94a3b8;
        font-size: 0.8rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.15s ease;
    }

    .bg-option.active {
        background: rgba(139, 92, 246, 0.2);
        border-color: rgba(139, 92, 246, 0.4);
        color: #e2e8f0;
    }

    .bg-option:hover:not(.active) {
        background: rgba(255, 255, 255, 0.08);
    }

    .rmbg-actions {
        margin-top: 1rem;
        display: flex;
        gap: 0.5rem;
    }

    .download-btn {
        padding: 0.5rem 1.2rem;
        border-radius: 8px;
        border: 1px solid rgba(52, 211, 153, 0.3);
        background: rgba(52, 211, 153, 0.1);
        color: #6ee7b7;
        font-weight: 600;
        font-size: 0.9rem;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .download-btn:hover {
        background: rgba(52, 211, 153, 0.2);
        transform: translateY(-1px);
    }

    .run-btn {
        margin-top: 1rem;
        padding: 0.6rem 1.5rem;
        border-radius: 8px;
        border: none;
        background: linear-gradient(135deg, #3b82f6 0%, #8b5cf6 100%);
        color: white;
        font-weight: 600;
        font-size: 0.95rem;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .model-needed {
        margin-top: 1rem;
        padding: 0.75rem 1rem;
        background: rgba(245, 158, 11, 0.08);
        border: 1px solid rgba(245, 158, 11, 0.2);
        border-radius: 8px;
        color: #fbbf24;
        font-size: 0.85rem;
    }

    .run-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(59, 130, 246, 0.3);
    }
</style>

@code {
    private string _selectedBackend = "WebGPU";
    private string? _imageDataUrl;
    private string? _resultImageUrl;
    private string _bgMode = "transparent";
    private bool _isRunning;
    private bool _isModelLoading;
    private bool _isModelLoaded;
    private double _modelProgress;
    private double _inferenceMs;

    private List<BackendSelector.BackendInfo> _backends = new()
    {
        new() { Id = "WebGPU", DisplayName = "WebGPU" },
        new() { Id = "WebGL", DisplayName = "WebGL" },
        new() { Id = "Wasm", DisplayName = "Wasm (CPU)" },
    };

    private List<ImageDropZone.SampleImage> _samples = new()
    {
        new() { Label = "Portrait", Url = "samples/portrait.jpg" },
        new() { Label = "Product", Url = "samples/product.jpg" },
    };

    [Inject] BlazorJS.BlazorJSRuntime JS { get; set; } = default!;

    private global::ILGPU.Runtime.Accelerator? _accelerator;
    private global::ILGPU.Context? _context;
    private SpawnDev.ILGPU.ML.Pipelines.BackgroundRemovalPipeline? _pipeline;
    private int[]? _rgbaPixels;
    private int _imageWidth, _imageHeight;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await LoadModelAsync();
    }

    private async Task LoadModelAsync()
    {
        try
        {
            _isModelLoading = true;
            StateHasChanged();

            if (_context == null)
            {
                var builder = SpawnDev.ILGPU.ML.MLContext.Create();
                await builder.AllAcceleratorsAsync();
                _context = builder.ToContext();
            }

            _accelerator = await _context.CreatePreferredAcceleratorAsync();
            if (_accelerator == null) { _isModelLoading = false; StateHasChanged(); return; }

            using var hub = new SpawnDev.ILGPU.ML.Hub.ModelHub(JS);
            var modelBytes = await hub.LoadAsync(
                SpawnDev.ILGPU.ML.Hub.ModelHub.KnownModels.RMBG14,
                SpawnDev.ILGPU.ML.Hub.ModelHub.KnownFiles.OnnxModel);
            var session = SpawnDev.ILGPU.ML.InferenceSession.CreateFromFile(_accelerator, modelBytes);
            _pipeline = new SpawnDev.ILGPU.ML.Pipelines.BackgroundRemovalPipeline(session, _accelerator);

            _isModelLoaded = true;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[RemoveBg] Error: {ex.Message}");
        }
        finally
        {
            _isModelLoading = false;
            StateHasChanged();
        }
    }

    private Task HandleBackendChange(string backend) => LoadModelAsync();

    private async Task HandleImageLoaded(byte[] imageBytes)
    {
        _resultImageUrl = null;
        try
        {
            using var blob = new SpawnDev.BlazorJS.JSObjects.Blob(
                new[] { imageBytes }, new SpawnDev.BlazorJS.JSObjects.BlobOptions { Type = "image/jpeg" });
            using var window = JS.Get<SpawnDev.BlazorJS.JSObjects.Window>("window");
            using var bitmap = await window.CreateImageBitmap(blob);
            int w = (int)bitmap.Width; int h = (int)bitmap.Height;
            using var canvas = new SpawnDev.BlazorJS.JSObjects.HTMLCanvasElement();
            canvas.Width = w; canvas.Height = h;
            using var ctx = canvas.Get2DContext();
            ctx.DrawImage(bitmap, 0, 0, w, h);
            using var imageData = ctx.GetImageData(0, 0, w, h);
            using var data = imageData.Data;
            _rgbaPixels = data.Read<int>();
            _imageWidth = w; _imageHeight = h;

            if (_isModelLoaded)
                await RunRemoval();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[RemoveBg] Image decode error: {ex.Message}");
        }
    }

    private async Task RunRemoval()
    {
        if (_pipeline == null || _rgbaPixels == null) return;
        _isRunning = true;
        StateHasChanged();
        await Task.Yield();

        try
        {
            var result = await _pipeline.RemoveBackgroundAsync(_rgbaPixels, _imageWidth, _imageHeight);
            _inferenceMs = result.InferenceTimeMs;
            _resultImageUrl = Services.ImageDisplayHelper.ToDataUrl(JS, result.ResultPixels, result.Width, result.Height);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[RemoveBg] Error: {ex.Message}");
        }

        _isRunning = false;
        StateHasChanged();
    }

    private void DownloadResult()
    {
        if (_resultImageUrl == null) return;
        try
        {
            using var document = JS.Get<SpawnDev.BlazorJS.JSObjects.Document>("document");
            using var link = document.CreateElement<SpawnDev.BlazorJS.JSObjects.HTMLAnchorElement>("a");
            link.Href = _resultImageUrl;
            link.Download = "removed-bg.png";
            using var body = document.Body!;
            body.AppendChild(link);
            link.Click();
            body.RemoveChild(link);
        }
        catch { }
    }

    public void Dispose()
    {
        _pipeline?.Dispose();
        _accelerator?.Dispose();
        _context?.Dispose();
    }
}
