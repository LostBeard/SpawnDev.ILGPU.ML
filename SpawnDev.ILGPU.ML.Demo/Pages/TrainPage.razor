@page "/train"
@using SpawnDev.BlazorJS
@using SpawnDev.ILGPU.ML
@implements IDisposable

<PageTitle>Draw to Learn — SpawnDev.ILGPU.ML</PageTitle>

<DemoLayout Title="Draw to Learn"
            Description="Train a classifier in your browser. Draw samples, train on GPU, classify in real-time. Most ML engines only predict — ours learns."
            AvailableBackends="@_backends"
            SelectedBackend="@_selectedBackend"
            SelectedBackendChanged="@((v) => _selectedBackend = v)"
            OnBackendChange="@HandleBackendChange"
            InferenceTimeMs="@_inferenceMs"
            IsRunning="@_isRunning">

    <div class="train-instructions">
        <div class="step-badges">
            <span class="step-badge @(_step >= 1 ? "done" : "")">1. Draw Samples</span>
            <span class="step-arrow">&rarr;</span>
            <span class="step-badge @(_step >= 2 ? "done" : "")">2. Train</span>
            <span class="step-arrow">&rarr;</span>
            <span class="step-badge @(_step >= 3 ? "done" : "")">3. Classify</span>
        </div>
    </div>

    <div class="train-layout">
        <div class="classes-panel">
            <h3 class="panel-title">Classes</h3>
            @foreach (var cls in _classes)
            {
                <div class="class-row @(_selectedClass == cls.Name ? "selected" : "")">
                    <button class="class-select-btn" @onclick="() => _selectedClass = cls.Name">
                        <span class="class-color" style="background: @cls.Color;"></span>
                        <span class="class-name">@cls.Name</span>
                        <span class="class-count">@cls.SampleCount samples</span>
                    </button>
                    <button class="class-delete-btn" @onclick="() => RemoveClass(cls.Name)" title="Remove class">&times;</button>
                </div>
            }
            <div class="add-class-row">
                <input type="text" class="add-class-input" @bind="_newClassName" placeholder="New class name" />
                <button class="add-class-btn" @onclick="AddClass">+</button>
            </div>
        </div>

        <div class="canvas-panel">
            <div class="drawing-canvas">
                <canvas @ref="_canvasRef" width="280" height="280" class="draw-surface"
                        @onmousedown="StartDrawing"
                        @onmousemove="Draw"
                        @onmouseup="StopDrawing"
                        @onmouseleave="StopDrawing"
                        style="background: black; cursor: crosshair;"></canvas>
            </div>
            <div class="canvas-actions">
                <button class="canvas-btn" @onclick="SaveSample" disabled="@(string.IsNullOrEmpty(_selectedClass))">
                    Save to "@_selectedClass"
                </button>
                <button class="canvas-btn canvas-btn-clear" @onclick="ClearCanvas">Clear</button>
            </div>
        </div>

        <div class="results-panel">
            @if (_step >= 2 && _trainingProgress < 100)
            {
                <h3 class="panel-title">Training</h3>
                <div class="training-progress">
                    <div class="progress-bar">
                        <div class="progress-fill" style="width: @_trainingProgress%;"></div>
                    </div>
                    <span class="progress-text">Epoch @_currentEpoch / @_totalEpochs</span>
                    <span class="progress-text">Loss: @_currentLoss.ToString("F4")</span>
                </div>
            }
            else if (_step >= 3)
            {
                <h3 class="panel-title">Prediction</h3>
                <ConfidenceBars Predictions="@_predictions" MaxItems="@_classes.Count" />
            }
            else
            {
                <h3 class="panel-title">How It Works</h3>
                <ol class="how-it-works">
                    <li>Add 2+ classes (e.g., "Circle", "Square")</li>
                    <li>Draw 10-20 samples per class</li>
                    <li>Click "Train" — GPU trains a small neural network</li>
                    <li>Draw something new — the model classifies it live</li>
                </ol>
            }
        </div>
    </div>

    <div class="train-actions">
        @if (_step == 1 && TotalSamples >= 4)
        {
            <button class="run-btn" @onclick="StartTraining">
                Train on GPU (@TotalSamples samples, @_classes.Count classes)
            </button>
        }
    </div>

    <div class="train-note">
        This demo uses SpawnDev.ILGPU's GPU compute to run backpropagation directly in the browser. No server, no cloud — your drawings and model stay on your device. This proves the engine supports training, not just inference.
    </div>

    <PrivacyBadge />

</DemoLayout>

<style>
    .train-instructions { margin-bottom: 1rem; }
    .step-badges { display: flex; align-items: center; gap: 0.5rem; }
    .step-badge { padding: 0.3rem 0.7rem; border-radius: 12px; font-size: 0.8rem; font-weight: 600; background: rgba(255,255,255,0.05); color: #64748b; border: 1px solid rgba(255,255,255,0.08); }
    .step-badge.done { background: rgba(52,211,153,0.1); color: #34d399; border-color: rgba(52,211,153,0.25); }
    .step-arrow { color: #475569; }

    .train-layout { display: grid; grid-template-columns: 200px 300px 1fr; gap: 1rem; }

    .panel-title { color: #f1f5f9; font-size: 0.95rem; font-weight: 600; margin-bottom: 0.75rem; }

    .classes-panel { }
    .class-row { display: flex; align-items: center; margin-bottom: 0.3rem; }
    .class-row.selected .class-select-btn { background: rgba(139,92,246,0.15); border-color: rgba(139,92,246,0.3); }
    .class-select-btn { flex: 1; display: flex; align-items: center; gap: 0.4rem; padding: 0.4rem 0.6rem; border-radius: 6px; border: 1px solid rgba(255,255,255,0.08); background: rgba(255,255,255,0.03); color: #e2e8f0; font-size: 0.82rem; cursor: pointer; }
    .class-select-btn:hover { background: rgba(255,255,255,0.06); }
    .class-color { width: 12px; height: 12px; border-radius: 3px; }
    .class-name { flex: 1; }
    .class-count { color: #64748b; font-size: 0.72rem; font-family: monospace; }
    .class-delete-btn { background: none; border: none; color: #64748b; cursor: pointer; font-size: 1rem; padding: 0.2rem; }
    .class-delete-btn:hover { color: #f87171; }
    .add-class-row { display: flex; gap: 0.3rem; margin-top: 0.5rem; }
    .add-class-input { flex: 1; padding: 0.3rem 0.5rem; border-radius: 6px; border: 1px solid rgba(255,255,255,0.12); background: rgba(255,255,255,0.04); color: #e2e8f0; font-size: 0.82rem; }
    .add-class-input::placeholder { color: #475569; }
    .add-class-btn { width: 30px; border-radius: 6px; border: 1px solid rgba(52,211,153,0.3); background: rgba(52,211,153,0.1); color: #34d399; font-weight: 700; cursor: pointer; }

    .canvas-panel { text-align: center; }
    .drawing-canvas { display: inline-block; border: 2px solid rgba(255,255,255,0.15); border-radius: 10px; overflow: hidden; background: #0a0a0a; }
    .draw-surface { cursor: crosshair; }
    .canvas-actions { display: flex; gap: 0.5rem; justify-content: center; margin-top: 0.5rem; }
    .canvas-btn { padding: 0.35rem 0.75rem; border-radius: 6px; border: 1px solid rgba(139,92,246,0.3); background: rgba(139,92,246,0.1); color: #c4b5fd; font-size: 0.82rem; font-weight: 600; cursor: pointer; }
    .canvas-btn:disabled { opacity: 0.4; cursor: not-allowed; }
    .canvas-btn-clear { border-color: rgba(255,255,255,0.1); background: rgba(255,255,255,0.05); color: #94a3b8; }

    .results-panel { }
    .how-it-works { color: #94a3b8; font-size: 0.85rem; line-height: 1.6; padding-left: 1.2rem; }
    .training-progress { }
    .progress-bar { height: 8px; background: rgba(255,255,255,0.06); border-radius: 4px; overflow: hidden; margin-bottom: 0.5rem; }
    .progress-fill { height: 100%; background: linear-gradient(90deg, #3b82f6, #8b5cf6); border-radius: 4px; transition: width 0.3s; }
    .progress-text { color: #94a3b8; font-size: 0.8rem; font-family: monospace; display: block; }

    .train-actions { margin-top: 1rem; }
    .run-btn { padding: 0.6rem 1.5rem; border-radius: 8px; border: none; background: linear-gradient(135deg, #3b82f6, #8b5cf6); color: white; font-weight: 600; cursor: pointer; transition: all 0.2s; }
    .run-btn:hover { transform: translateY(-2px); box-shadow: 0 6px 16px rgba(59,130,246,0.3); }

    .train-note { margin-top: 1.5rem; padding: 0.75rem 1rem; background: rgba(56,189,248,0.06); border: 1px solid rgba(56,189,248,0.15); border-radius: 8px; color: #7dd3fc; font-size: 0.85rem; line-height: 1.5; }

    @@media (max-width: 768px) { .train-layout { grid-template-columns: 1fr; } }
</style>

@code {
    private string _selectedBackend = "WebGPU";
    private string _selectedClass = "";
    private string _newClassName = "";
    private int _step = 1;
    private float _trainingProgress;
    private int _currentEpoch, _totalEpochs = 50;
    private float _currentLoss;
    private bool _isRunning;
    private double _inferenceMs;
    private List<ConfidenceBars.Prediction>? _predictions;

    private List<DrawClass> _classes = new()
    {
        new() { Name = "Circle", Color = "#3b82f6" },
        new() { Name = "Square", Color = "#ef4444" },
    };

    private int TotalSamples => _classes.Sum(c => c.SampleCount);

    private List<BackendSelector.BackendInfo> _backends = new()
    {
        new() { Id = "WebGPU", DisplayName = "WebGPU" },
        new() { Id = "CPU", DisplayName = "CPU" },
    };

    [Inject] BlazorJS.BlazorJSRuntime JS { get; set; } = default!;

    private global::ILGPU.Runtime.Accelerator? _accelerator;
    private global::ILGPU.Context? _context;
    private SpawnDev.ILGPU.ML.Training.TrainableModel? _model;
    private ElementReference _canvasRef;
    private bool _isDrawing;
    private List<List<float[]>> _trainingSamples = new(); // per-class samples, each 28*28 floats
    private float _lastX, _lastY;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            if (_context == null)
            {
                var builder = SpawnDev.ILGPU.ML.MLContext.Create();
                await builder.AllAcceleratorsAsync();
                _context = builder.ToContext();
            }
            _accelerator = await _context.CreatePreferredAcceleratorAsync();
            // Initialize per-class sample storage
            foreach (var _ in _classes)
                _trainingSamples.Add(new List<float[]>());
        }
    }

    private Task HandleBackendChange(string backend) { _selectedBackend = backend; return Task.CompletedTask; }
    private void AddClass()
    {
        if (!string.IsNullOrWhiteSpace(_newClassName))
        {
            _classes.Add(new DrawClass { Name = _newClassName, Color = GetNextColor() });
            _trainingSamples.Add(new List<float[]>());
            _newClassName = "";
        }
    }
    private void RemoveClass(string name)
    {
        int idx = _classes.FindIndex(c => c.Name == name);
        if (idx >= 0) { _classes.RemoveAt(idx); _trainingSamples.RemoveAt(idx); }
    }

    private void StartDrawing(Microsoft.AspNetCore.Components.Web.MouseEventArgs e)
    {
        _isDrawing = true;
        _lastX = (float)e.OffsetX;
        _lastY = (float)e.OffsetY;
        // Draw a dot at the start position
        DrawOnCanvas(_lastX, _lastY, _lastX, _lastY);
    }

    private void Draw(Microsoft.AspNetCore.Components.Web.MouseEventArgs e)
    {
        if (!_isDrawing) return;
        float x = (float)e.OffsetX, y = (float)e.OffsetY;
        DrawOnCanvas(_lastX, _lastY, x, y);
        _lastX = x; _lastY = y;
    }

    private void StopDrawing() { _isDrawing = false; }

    private void DrawOnCanvas(float x1, float y1, float x2, float y2)
    {
        using var canvas = new SpawnDev.BlazorJS.JSObjects.HTMLCanvasElement(_canvasRef);
        using var ctx = canvas.Get2DContext();
        ctx.StrokeStyle = "white";
        ctx.LineWidth = 12;
        ctx.LineCap = "round";
        ctx.BeginPath();
        ctx.MoveTo(x1, y1);
        ctx.LineTo(x2, y2);
        ctx.Stroke();
    }

    private void SaveSample()
    {
        if (string.IsNullOrEmpty(_selectedClass)) return;
        int classIdx = _classes.FindIndex(c => c.Name == _selectedClass);
        if (classIdx < 0) return;

        // Read canvas pixels and downsample to 28x28 grayscale
        using var canvas = new SpawnDev.BlazorJS.JSObjects.HTMLCanvasElement(_canvasRef);
        using var ctx = canvas.Get2DContext();
        using var imageData = ctx.GetImageData(0, 0, 280, 280);
        using var data = imageData.Data;
        var pixels = data.ReadBytes();

        // Downsample 280x280 → 28x28 by averaging 10x10 blocks
        var sample = new float[28 * 28];
        for (int y = 0; y < 28; y++)
        {
            for (int x = 0; x < 28; x++)
            {
                float sum = 0;
                for (int dy = 0; dy < 10; dy++)
                    for (int dx = 0; dx < 10; dx++)
                    {
                        int srcIdx = ((y * 10 + dy) * 280 + (x * 10 + dx)) * 4;
                        if (srcIdx + 3 < pixels.Length)
                            sum += pixels[srcIdx]; // R channel (white = 255)
                    }
                sample[y * 28 + x] = sum / (10 * 10 * 255f);
            }
        }

        _trainingSamples[classIdx].Add(sample);
        _classes[classIdx].SampleCount++;
        ClearCanvas();
        StateHasChanged();
    }

    private void ClearCanvas()
    {
        using var canvas = new SpawnDev.BlazorJS.JSObjects.HTMLCanvasElement(_canvasRef);
        using var ctx = canvas.Get2DContext();
        ctx.ClearRect(0, 0, 280, 280);
    }

    private async Task StartTraining()
    {
        if (_accelerator == null || _classes.Count < 2) return;
        int totalSamples = _trainingSamples.Sum(s => s.Count);
        if (totalSamples < 4) return; // Need at least a few samples

        _step = 2;
        _isRunning = true;
        StateHasChanged();
        await Task.Yield();

        try
        {
            // Build model: 784 → 64 → ReLU → numClasses
            _model?.Dispose();
            _model = new SpawnDev.ILGPU.ML.Training.TrainableModel(_accelerator);
            _model.AddLinear(28 * 28, 64);
            _model.AddReLU();
            _model.AddLinear(64, _classes.Count);
            _model.Build(maxBatchSize: totalSamples);

            // Flatten training data into batch
            var inputData = new float[totalSamples * 28 * 28];
            var labels = new int[totalSamples];
            int idx = 0;
            for (int c = 0; c < _trainingSamples.Count; c++)
            {
                foreach (var sample in _trainingSamples[c])
                {
                    Array.Copy(sample, 0, inputData, idx * 28 * 28, 28 * 28);
                    labels[idx] = c;
                    idx++;
                }
            }

            // Train
            for (int epoch = 0; epoch < _totalEpochs; epoch++)
            {
                _currentEpoch = epoch + 1;
                _currentLoss = await _model.TrainStepAsync(inputData, labels, totalSamples, learningRate: 0.01f);
                _trainingProgress = (epoch + 1f) / _totalEpochs * 100f;

                if (epoch % 5 == 0)
                {
                    StateHasChanged();
                    await Task.Yield();
                }
            }

            _step = 3;
            _trainingProgress = 100;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Train] Error: {ex.Message}");
        }

        _isRunning = false;
        StateHasChanged();
    }

    private string GetNextColor() => _classes.Count switch
    {
        0 => "#3b82f6", 1 => "#ef4444", 2 => "#22c55e", 3 => "#f59e0b",
        4 => "#8b5cf6", 5 => "#ec4899", 6 => "#14b8a6", 7 => "#f97316",
        _ => "#64748b",
    };

    public void Dispose()
    {
        _model?.Dispose();
        _accelerator?.Dispose();
        _context?.Dispose();
    }

    private class DrawClass { public string Name { get; set; } = ""; public string Color { get; set; } = ""; public int SampleCount { get; set; } }
}
