@page "/models"
@using SpawnDev.ILGPU.ML.Onnx

<PageTitle>Models — SpawnDev.ILGPU.ML</PageTitle>

<div class="models-page">
    <div class="models-header">
        <h1 class="models-title">Available Models</h1>
        <p class="models-desc">
            Models available for inference demos. Drop your own .onnx file on the
            <a href="inspector">Model Inspector</a> to check compatibility.
        </p>
    </div>

    <div class="models-grid">
        @foreach (var group in _models.GroupBy(m => m.Task))
        {
            <div class="task-group">
                <h2 class="task-title">@FormatTaskName(group.Key)</h2>
                <div class="model-cards">
                    @foreach (var model in group)
                    {
                        <div class="model-card">
                            <div class="model-info">
                                <span class="model-name">@model.Name</span>
                                <span class="model-size">@model.SizeMB.ToString("F1") MB</span>
                            </div>
                            <p class="model-desc">@model.Description</p>
                            @if (model.InputWidth > 0)
                            {
                                <span class="model-input">Input: @(model.InputWidth)x@(model.InputHeight)</span>
                            }
                            <div class="model-footer">
                                <div class="model-formats">
                                    @if (model.HasOnnxFormat)
                                    {
                                        <span class="format-badge format-onnx">ONNX</span>
                                    }
                                    @if (model.HuggingFaceUrl != null)
                                    {
                                        <a href="@model.HuggingFaceUrl" target="_blank" class="format-badge format-hf">HF</a>
                                    }
                                </div>
                                @if (!string.IsNullOrEmpty(model.DemoUrl))
                                {
                                    <a href="@model.DemoUrl" class="model-try-link">Try it</a>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    <div class="custom-model-section">
        <h2 class="section-title">Load Custom Model</h2>
        <p class="section-desc">
            Enter a HuggingFace model URL or repo ID to load any ONNX model directly.
            Uses our zero-dependency ONNX parser — no server needed.
        </p>
        <div class="custom-input-row">
            <input type="text" class="custom-input" placeholder="e.g., onnx-community/mobilenetv2-12"
                   @bind="_customRepoId" />
            <input type="text" class="custom-input custom-input-file" placeholder="onnx/model.onnx"
                   @bind="_customFilename" />
            <button class="load-btn" @onclick="LoadCustomModel" disabled="@_isLoading">
                @(_isLoading ? "Loading..." : "Load")
            </button>
        </div>
        @if (_customResult != null)
        {
            <div class="custom-result">
                <span class="result-icon">@(_compatResult?.IsFullySupported == true ? "&#x2705;" : _compatResult != null ? "&#x26A0;" : "&#x23F3;")</span>
                <span>@_customResult</span>
            </div>
        }
        @if (_inspectionResult != null)
        {
            <div class="inspect-summary">
                <div class="inspect-row"><span>Inputs:</span><span>@string.Join(", ", _inspectionResult.Inputs.Select(i => $"{i.Name} [{string.Join(",", i.Shape)}]"))</span></div>
                <div class="inspect-row"><span>Outputs:</span><span>@string.Join(", ", _inspectionResult.Outputs.Select(o => $"{o.Name} [{string.Join(",", o.Shape)}]"))</span></div>
                <div class="inspect-row"><span>Operators:</span><span>@string.Join(", ", _inspectionResult.Operators.OrderByDescending(o => o.Count).Take(10).Select(o => $"{o.OpType}({o.Count})"))</span></div>
                @if (_compatResult?.IsFullySupported == true)
                {
                    <div class="inspect-compatible">This model can run on SpawnDev.ILGPU.ML</div>
                }
            </div>
        }
        @if (_customError != null)
        {
            <div class="custom-error">@_customError</div>
        }
    </div>

    <PrivacyBadge />
</div>

<style>
    .models-page { max-width: 960px; margin: 0 auto; }
    .models-header { margin-bottom: 1.5rem; }
    .models-title { font-size: 1.6rem; font-weight: 700; color: #f1f5f9; margin-bottom: 0.25rem; }
    .models-desc { color: #64748b; font-size: 0.95rem; }
    .models-desc a { color: #3b82f6; text-decoration: none; }
    .models-desc a:hover { text-decoration: underline; }

    .task-group { margin-bottom: 2rem; }
    .task-title { font-size: 1.15rem; font-weight: 600; color: #cbd5e1; margin-bottom: 0.75rem; }

    .model-cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 1rem; }
    .model-card {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 10px;
        padding: 1rem;
        transition: all 0.15s;
    }
    .model-card:hover { border-color: rgba(139,92,246,0.25); background: rgba(255,255,255,0.05); }

    .model-info { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 0.4rem; }
    .model-name { color: #f1f5f9; font-weight: 600; font-size: 0.95rem; }
    .model-size { color: #64748b; font-size: 0.8rem; font-family: monospace; }
    .model-desc { color: #94a3b8; font-size: 0.82rem; margin: 0 0 0.5rem 0; line-height: 1.4; }
    .model-input { color: #475569; font-size: 0.75rem; font-family: monospace; }

    .model-footer { display: flex; justify-content: space-between; align-items: center; margin-top: 0.5rem; }
    .model-formats { display: flex; gap: 0.3rem; }
    .model-try-link { color: #3b82f6; font-size: 0.8rem; font-weight: 600; text-decoration: none; }
    .model-try-link:hover { color: #60a5fa; text-decoration: underline; }
    .format-badge { font-size: 0.68rem; font-weight: 700; padding: 0.15rem 0.4rem; border-radius: 4px; text-transform: uppercase; }
    .format-onnx { background: rgba(56,189,248,0.1); border: 1px solid rgba(56,189,248,0.25); color: #38bdf8; }
    .format-hf { background: rgba(255,216,77,0.1); border: 1px solid rgba(255,216,77,0.25); color: #ffd84d; text-decoration: none; cursor: pointer; }
    .format-hf:hover { background: rgba(255,216,77,0.2); }

    .custom-model-section { margin-top: 2rem; padding: 1.5rem; background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.06); border-radius: 10px; }
    .section-title { font-size: 1.1rem; font-weight: 600; color: #f1f5f9; margin-bottom: 0.3rem; }
    .section-desc { color: #64748b; font-size: 0.9rem; margin-bottom: 1rem; }

    .custom-input-row { display: flex; gap: 0.5rem; flex-wrap: wrap; }
    .custom-input {
        flex: 1;
        min-width: 200px;
        padding: 0.5rem 0.75rem;
        border-radius: 6px;
        border: 1px solid rgba(255,255,255,0.12);
        background: rgba(255,255,255,0.04);
        color: #e2e8f0;
        font-size: 0.9rem;
    }
    .custom-input-file { flex: 0.6; min-width: 150px; }
    .custom-input::placeholder { color: #475569; }
    .custom-input:focus { border-color: rgba(139,92,246,0.5); outline: none; }

    .load-btn {
        padding: 0.5rem 1.2rem;
        border-radius: 6px;
        border: none;
        background: linear-gradient(135deg, #3b82f6, #8b5cf6);
        color: white;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.15s;
    }
    .load-btn:hover { transform: translateY(-1px); box-shadow: 0 4px 12px rgba(59,130,246,0.3); }
    .load-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

    .custom-result { display: flex; align-items: center; gap: 0.5rem; margin-top: 0.75rem; color: #6ee7b7; font-size: 0.9rem; }
    .inspect-summary { margin-top: 0.75rem; padding: 0.75rem; background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.06); border-radius: 8px; }
    .inspect-row { display: flex; gap: 0.5rem; padding: 0.2rem 0; font-size: 0.82rem; }
    .inspect-row span:first-child { color: #64748b; min-width: 70px; }
    .inspect-row span:last-child { color: #cbd5e1; font-family: monospace; font-size: 0.78rem; word-break: break-all; }
    .inspect-compatible { margin-top: 0.5rem; color: #34d399; font-size: 0.85rem; font-weight: 600; }
    .custom-error { margin-top: 0.75rem; color: #fca5a5; font-size: 0.9rem; }
</style>

@code {
    private List<ModelEntry> _models = new();
    private string _customRepoId = "";
    private string _customFilename = "onnx/model.onnx";
    private bool _isLoading;
    private string? _customResult;
    private string? _customError;

    protected override void OnInitialized()
    {
        _models = new List<ModelEntry>
        {
            new() { Id = "squeezenet", Name = "SqueezeNet 1.1", Task = "Classification", HuggingFaceRepo = "onnxmodelzoo/squeezenet1.1-7", OnnxFile = "squeezenet1.1-7.onnx", SizeMB = 4.8, Description = "Fast 1000-class ImageNet classification", InputWidth = 224, InputHeight = 224, DemoUrl = "classify" },
            new() { Id = "mobilenetv2", Name = "MobileNetV2", Task = "Classification", HuggingFaceRepo = "onnxmodelzoo/mobilenetv2-12", OnnxFile = "mobilenetv2-12.onnx", SizeMB = 14, Description = "Accurate 1000-class ImageNet classification", InputWidth = 224, InputHeight = 224, DemoUrl = "classify" },
            new() { Id = "depth-anything-v2", Name = "Depth Anything V2 Small", Task = "Depth Estimation", HuggingFaceRepo = "onnx-community/depth-anything-v2-small", OnnxFile = "onnx/model.onnx", SizeMB = 95, Description = "Monocular depth estimation (26M params)", InputWidth = 518, InputHeight = 518, DemoUrl = "depth" },
            new() { Id = "style-mosaic", Name = "Mosaic", Task = "Style Transfer", HuggingFaceRepo = "onnxmodelzoo/mosaic-9", OnnxFile = "mosaic-9.onnx", SizeMB = 6.5, Description = "Mosaic tile artistic style", DemoUrl = "style" },
            new() { Id = "style-candy", Name = "Candy", Task = "Style Transfer", HuggingFaceRepo = "onnxmodelzoo/candy-9", OnnxFile = "candy-9.onnx", SizeMB = 6.5, Description = "Bright candy-colored artistic style", DemoUrl = "style" },
            new() { Id = "style-rain-princess", Name = "Rain Princess", Task = "Style Transfer", HuggingFaceRepo = "onnxmodelzoo/rain-princess-9", OnnxFile = "rain-princess-9.onnx", SizeMB = 6.5, Description = "Impressionist rain scene style", DemoUrl = "style" },
            new() { Id = "style-udnie", Name = "Udnie", Task = "Style Transfer", HuggingFaceRepo = "onnxmodelzoo/udnie-9", OnnxFile = "udnie-9.onnx", SizeMB = 6.5, Description = "Abstract cubist style", DemoUrl = "style" },
            new() { Id = "style-pointilism", Name = "Pointilism", Task = "Style Transfer", HuggingFaceRepo = "onnxmodelzoo/pointilism-9", OnnxFile = "pointilism-9.onnx", SizeMB = 6.5, Description = "Pointillist dot painting style", DemoUrl = "style" },
            new() { Id = "super-resolution", Name = "ESPCN (3x)", Task = "Super Resolution", HuggingFaceRepo = "onnxmodelzoo/super-resolution-10", OnnxFile = "super-resolution-10.onnx", SizeMB = 0.2, Description = "3x upscaling (224→672)", InputWidth = 224, InputHeight = 224, DemoUrl = "super-res" },
            new() { Id = "movenet-lightning", Name = "MoveNet Lightning", Task = "Pose Estimation", HuggingFaceRepo = "Xenova/movenet-singlepose-lightning", OnnxFile = "onnx/model.onnx", SizeMB = 9, Description = "Fast 17-keypoint pose detection", InputWidth = 192, InputHeight = 192, DemoUrl = "pose" },
            new() { Id = "yolov8n", Name = "YOLOv8 Nano", Task = "Object Detection", HuggingFaceRepo = "salim4n/yolov8n-detect-onnx", OnnxFile = "yolov8n-onnx-web/yolov8n.onnx", SizeMB = 12.2, Description = "80-class COCO detection (person, car, dog, ...)", InputWidth = 640, InputHeight = 640, DemoUrl = "detect" },
            new() { Id = "distilbert-sst2", Name = "DistilBERT SST-2", Task = "Text Classification", HuggingFaceRepo = "Xenova/distilbert-base-uncased-finetuned-sst-2-english", OnnxFile = "onnx/model.onnx", SizeMB = 257, Description = "Sentiment analysis (positive/negative)", DemoUrl = "embeddings" },
            new() { Id = "whisper-tiny", Name = "Whisper Tiny", Task = "Speech Recognition", HuggingFaceRepo = "onnx-community/whisper-tiny", OnnxFile = "onnx/encoder_model.onnx", SizeMB = 226, Description = "OpenAI Whisper speech-to-text", DemoUrl = "whisper" },
            new() { Id = "rmbg-1.4", Name = "RMBG 1.4", Task = "Background Removal", HuggingFaceRepo = "Xenova/rmbg-1.4", OnnxFile = "onnx/model.onnx", SizeMB = 44, Description = "Salient object segmentation for background removal", InputWidth = 1024, InputHeight = 1024, DemoUrl = "remove-bg" },
            new() { Id = "clip-vit-b32", Name = "CLIP ViT-B/32", Task = "Zero-Shot Classification", HuggingFaceRepo = "Xenova/clip-vit-base-patch32", OnnxFile = "onnx/vision_model.onnx", SizeMB = 335, Description = "Classify images into any text categories — no training needed", InputWidth = 224, InputHeight = 224, DemoUrl = "clip" },
        };
    }

    [Inject] HttpClient Http { get; set; } = default!;

    private InspectionResult? _inspectionResult;
    private CompatibilityResult? _compatResult;

    private async Task LoadCustomModel()
    {
        if (string.IsNullOrWhiteSpace(_customRepoId)) return;
        _isLoading = true;
        _customResult = null;
        _customError = null;
        _inspectionResult = null;
        _compatResult = null;
        StateHasChanged();

        try
        {
            var url = $"https://huggingface.co/{_customRepoId}/resolve/main/{_customFilename}";
            _customResult = $"Downloading from {url}...";
            StateHasChanged();

            var bytes = await Http.GetByteArrayAsync(url);
            _customResult = $"Downloaded {(bytes.Length / 1024.0 / 1024.0):F1} MB. Inspecting...";
            StateHasChanged();

            _inspectionResult = ModelInspectorHelper.Inspect(bytes);
            _compatResult = ModelInspectorHelper.CheckCompatibility(bytes);

            _customResult = $"{_inspectionResult.GraphName}: {_inspectionResult.NodeCount} nodes, " +
                $"{_inspectionResult.TotalParameters:N0} params, " +
                $"{_inspectionResult.Operators.Length} op types — " +
                $"{(_compatResult.IsFullySupported ? "Fully compatible" : $"{_compatResult.CompatibilityPercent:F0}% compatible")}";

            if (_compatResult.UnsupportedOps.Length > 0)
                _customResult += $" (unsupported: {string.Join(", ", _compatResult.UnsupportedOps)})";
        }
        catch (HttpRequestException ex)
        {
            _customError = $"Download failed: {ex.Message}. Check the repo ID and filename.";
        }
        catch (Exception ex)
        {
            _customError = $"Error: {ex.Message}";
        }

        _isLoading = false;
        StateHasChanged();
    }

    private string FormatTaskName(string task) => task;

    private class ModelEntry
    {
        public string Id { get; init; } = "";
        public string Name { get; init; } = "";
        public string Task { get; init; } = "";
        public string? HuggingFaceRepo { get; init; }
        public string? OnnxFile { get; init; }
        public double SizeMB { get; init; }
        public string Description { get; init; } = "";
        public int InputWidth { get; init; }
        public int InputHeight { get; init; }
        public string? DemoUrl { get; init; }
        public bool HasOnnxFormat => OnnxFile != null;
        public string? HuggingFaceUrl => HuggingFaceRepo != null ? $"https://huggingface.co/{HuggingFaceRepo}" : null;
    }
}
