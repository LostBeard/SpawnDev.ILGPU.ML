@page "/detect"
@using SpawnDev.BlazorJS
@using SpawnDev.ILGPU.ML
@using SpawnDev.ILGPU.ML.Hub
@using SpawnDev.ILGPU.ML.Pipelines
@implements IDisposable

<PageTitle>Object Detection — SpawnDev.ILGPU.ML</PageTitle>

<DemoLayout Title="Object Detection"
            Description="Real-time object detection using YOLOv8-Nano. Use your webcam or upload an image."
            AvailableBackends="@_backends"
            SelectedBackend="@_selectedBackend"
            SelectedBackendChanged="@((v) => _selectedBackend = v)"
            OnBackendChange="@HandleBackendChange"
            InferenceTimeMs="@_inferenceMs"
            IsRunning="@_isRunning"
            ShowFps="true"
            ShowModelProgress="true"
            ModelName="YOLOv8-Nano"
            IsModelLoading="@_isModelLoading"
            IsModelLoaded="@_isModelLoaded"
            ModelProgressPercent="@_modelProgress"
            ModelSizeMB="4">

    <div class="detect-controls">
        <label class="threshold-label">Confidence:</label>
        <input type="range" min="10" max="95" step="5" @bind="_confidenceThreshold" class="threshold-slider" />
        <span class="threshold-value">@_confidenceThreshold%</span>

        <div class="mode-toggle">
            <button class="mode-btn @(_useWebcam ? "" : "active")" @onclick="() => _useWebcam = false">Image</button>
            <button class="mode-btn @(_useWebcam ? "active" : "")" @onclick="() => _useWebcam = true">Webcam</button>
        </div>
    </div>

    @if (_useWebcam)
    {
        <BoundingBoxOverlay Detections="@_detections"
                            ImageWidth="640" ImageHeight="480"
                            ConfidenceThreshold="@(_confidenceThreshold / 100f)">
            <WebcamCapture OnFrameCaptured="@HandleFrame"
                           AutoCapture="true"
                           CaptureIntervalMs="100"
                           ShowCaptureButton="false" />
        </BoundingBoxOverlay>
    }
    else
    {
        <BoundingBoxOverlay Detections="@_detections"
                            ImageWidth="640" ImageHeight="480"
                            ConfidenceThreshold="@(_confidenceThreshold / 100f)">
            <ImageDropZone @bind-ImageDataUrl="_imageDataUrl"
                           OnImageLoaded="@HandleImageLoaded" />
        </BoundingBoxOverlay>
    }

    @if (_detections?.Any() == true)
    {
        <div class="detection-summary">
            @foreach (var group in _detections
                .Where(d => d.Confidence >= _confidenceThreshold / 100f)
                .GroupBy(d => d.Label)
                .OrderByDescending(g => g.Count()))
            {
                <span class="detection-chip">@group.Key (@group.Count())</span>
            }
        </div>
    }

    @if (!_isModelLoaded && !_isModelLoading)
    {
        <div class="model-needed">
            Loading YOLOv8-Nano (12MB) from HuggingFace CDN. Model will be cached locally after first download.
        </div>
    }

    <PrivacyBadge />

</DemoLayout>

<style>
    .detect-controls {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 1rem;
        flex-wrap: wrap;
    }

    .threshold-label {
        color: #64748b;
        font-size: 0.85rem;
    }

    .threshold-slider {
        width: 120px;
        accent-color: #8b5cf6;
    }

    .threshold-value {
        color: #94a3b8;
        font-size: 0.8rem;
        font-family: 'JetBrains Mono', 'Consolas', monospace;
        min-width: 35px;
    }

    .mode-toggle {
        display: flex;
        border-radius: 6px;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.1);
        margin-left: auto;
    }

    .mode-btn {
        padding: 0.3rem 0.75rem;
        border: none;
        background: rgba(255, 255, 255, 0.04);
        color: #64748b;
        font-size: 0.8rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.15s ease;
    }

    .mode-btn.active {
        background: rgba(139, 92, 246, 0.2);
        color: #e2e8f0;
    }

    .mode-btn:hover:not(.active) {
        background: rgba(255, 255, 255, 0.08);
    }

    .detection-summary {
        display: flex;
        gap: 0.4rem;
        flex-wrap: wrap;
        margin-top: 0.75rem;
    }

    .detection-chip {
        padding: 0.2rem 0.6rem;
        border-radius: 12px;
        background: rgba(139, 92, 246, 0.12);
        border: 1px solid rgba(139, 92, 246, 0.25);
        color: #c4b5fd;
        font-size: 0.78rem;
        font-weight: 600;
    }

    .model-needed {
        margin-top: 1rem;
        padding: 0.75rem 1rem;
        background: rgba(245, 158, 11, 0.08);
        border: 1px solid rgba(245, 158, 11, 0.2);
        border-radius: 8px;
        color: #fbbf24;
        font-size: 0.85rem;
    }
</style>

@code {
    private string _selectedBackend = "WebGPU";
    private string? _imageDataUrl;
    private bool _useWebcam;
    private int _confidenceThreshold = 50;
    private bool _isRunning;
    private bool _isModelLoading;
    private bool _isModelLoaded;
    private double _modelProgress;
    private double _inferenceMs;
    private List<BoundingBoxOverlay.Detection>? _detections;

    private List<BackendSelector.BackendInfo> _backends = new()
    {
        new() { Id = "WebGPU", DisplayName = "WebGPU" },
        new() { Id = "WebGL", DisplayName = "WebGL" },
        new() { Id = "Wasm", DisplayName = "Wasm (CPU)" },
    };

    [Inject] BlazorJS.BlazorJSRuntime JS { get; set; } = default!;

    private global::ILGPU.Runtime.Accelerator? _accelerator;
    private global::ILGPU.Context? _context;
    private Pipelines.ObjectDetectionPipeline? _pipeline;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await LoadModelAsync();
    }

    private async Task LoadModelAsync()
    {
        try
        {
            _isModelLoading = true;
            StateHasChanged();

            if (_context == null)
            {
                var builder = MLContext.Create();
                await builder.AllAcceleratorsAsync();
                _context = builder.ToContext();
            }

            _accelerator = await _context.CreatePreferredAcceleratorAsync();
            if (_accelerator == null) { _isModelLoading = false; StateHasChanged(); return; }

            using var hub = new Hub.ModelHub(JS);
            var modelBytes = await hub.LoadAsync(Hub.ModelHub.KnownModels.YOLOv8n, "yolov8n-onnx-web/yolov8n.onnx");
            var session = InferenceSession.CreateFromFile(_accelerator, modelBytes);
            _pipeline = new Pipelines.ObjectDetectionPipeline(session, _accelerator);

            _isModelLoaded = true;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Detect] Error: {ex.Message}");
        }
        finally
        {
            _isModelLoading = false;
            StateHasChanged();
        }
    }

    private bool _processingFrame;

    private Task HandleBackendChange(string backend) => LoadModelAsync();

    private async Task HandleImageLoaded(byte[] imageBytes)
    {
        if (_pipeline == null || _isModelLoading) return;
        try
        {
            // Decode image file bytes to RGBA via browser createImageBitmap
            using var blob = new SpawnDev.BlazorJS.JSObjects.Blob(
                new[] { imageBytes }, new SpawnDev.BlazorJS.JSObjects.BlobOptions { Type = "image/png" });
            using var window = JS.Get<SpawnDev.BlazorJS.JSObjects.Window>("window");
            using var bitmap = await window.CreateImageBitmap(blob);
            int w = (int)bitmap.Width;
            int h = (int)bitmap.Height;
            using var canvas = new SpawnDev.BlazorJS.JSObjects.HTMLCanvasElement();
            canvas.Width = w;
            canvas.Height = h;
            using var ctx = canvas.Get2DContext();
            ctx.DrawImage(bitmap, 0, 0, w, h);
            using var imageData = ctx.GetImageData(0, 0, w, h);
            using var data = imageData.Data;
            var rgbaPixels = data.Read<int>();

            await RunDetection(rgbaPixels, w, h);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Detect] Image decode error: {ex.Message}");
        }
    }

    private async Task HandleFrame(byte[] frameBytes)
    {
        if (_pipeline == null || _processingFrame) return;
        _processingFrame = true;
        try
        {
            // Convert RGBA byte[] to int[] (pack 4 bytes per pixel)
            var rgbaPixels = new int[frameBytes.Length / 4];
            Buffer.BlockCopy(frameBytes, 0, rgbaPixels, 0, frameBytes.Length);
            await RunDetection(rgbaPixels, 640, 480);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Detect] Frame error: {ex.Message}");
        }
        finally
        {
            _processingFrame = false;
        }
    }

    private async Task RunDetection(int[] rgbaPixels, int width, int height)
    {
        _isRunning = true;
        try
        {
            var result = await _pipeline!.DetectAsync(
                rgbaPixels, width, height,
                confidenceThreshold: _confidenceThreshold / 100f);
            _inferenceMs = result.InferenceTimeMs;
            _detections = result.Objects.Select(o => new BoundingBoxOverlay.Detection
            {
                X = o.X,
                Y = o.Y,
                Width = o.Width,
                Height = o.Height,
                Label = o.Label,
                ClassId = o.ClassId,
                Confidence = o.Confidence,
            }).ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Detect] Inference error: {ex.Message}");
        }
        _isRunning = false;
        StateHasChanged();
    }

    public void Dispose()
    {
        _pipeline?.Dispose();
        _accelerator?.Dispose();
        _context?.Dispose();
    }
}
