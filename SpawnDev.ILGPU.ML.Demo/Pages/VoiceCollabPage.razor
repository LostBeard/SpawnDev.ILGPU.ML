@page "/voice-collab"

<PageTitle>Voice Collaboration - SpawnDev.ILGPU.ML</PageTitle>

<div class="vc-page">
    <div class="vc-header">
        <h1 class="vc-title">Voice Collaboration</h1>
        <p class="vc-description">Talk to your AI dev team. Speech-to-text transcribes your voice, agents respond with distinct voices via text-to-speech. All audio processing runs in your browser.</p>
    </div>

    <div class="vc-transcript" @ref="_transcriptEl">
        @if (_transcript.Count == 0)
        {
            <div class="vc-empty">
                <p>Click <strong>Start Listening</strong> to begin. Speak naturally — your voice is transcribed locally and routed to the active agent.</p>
                <p style="font-size: 0.85rem; color: #888;">Phase 1: Web Speech API for STT/TTS. Future: Whisper on GPU + local LLM.</p>
            </div>
        }
        @foreach (var entry in _transcript)
        {
            <div class="vc-entry vc-entry-@entry.Role">
                <span class="vc-speaker">[@entry.Speaker]</span>
                <span class="vc-time">@entry.Timestamp.ToString("HH:mm:ss")</span>
                <div class="vc-text">@entry.Text</div>
            </div>
        }
        @if (_isProcessing)
        {
            <div class="vc-entry vc-entry-agent">
                <span class="vc-speaker">[@_activeAgent.Name]</span>
                <span class="vc-thinking">thinking...</span>
            </div>
        }
    </div>

    <div class="vc-controls">
        <div class="vc-buttons">
            @if (!_isListening)
            {
                <button class="vc-btn vc-btn-start" @onclick="StartListening" disabled="@(!_speechSupported)">
                    Start Listening
                </button>
            }
            else
            {
                <button class="vc-btn vc-btn-stop" @onclick="StopListening">
                    Stop Listening
                </button>
            }
            <button class="vc-btn vc-btn-clear" @onclick="ClearTranscript" disabled="@(_transcript.Count == 0)">
                Clear
            </button>
        </div>

        <div class="vc-status">
            @if (!_speechSupported)
            {
                <span style="color: #d32f2f;">Web Speech API not supported in this browser.</span>
            }
            else if (_isListening)
            {
                <span style="color: #2e7d32;">Listening...</span>
            }
            else
            {
                <span style="color: #777;">Ready</span>
            }
        </div>
    </div>

    <div class="vc-settings">
        <div class="vc-setting-group">
            <label>Active Agent:</label>
            <div class="vc-agent-list">
                @foreach (var agent in _agents)
                {
                    <button class="vc-agent-btn @(agent == _activeAgent ? "active" : "")"
                            @onclick="() => SetActiveAgent(agent)">
                        @agent.Name
                    </button>
                }
            </div>
        </div>

        <div class="vc-setting-group">
            <label>STT Engine:</label>
            <select @bind="_sttEngine" class="vc-select">
                <option value="webspeech">Web Speech API</option>
                <option value="whisper" disabled>Whisper on GPU (requires model download)</option>
            </select>
        </div>

        <div class="vc-setting-group">
            <label>LLM Backend:</label>
            <select @bind="_llmBackend" class="vc-select">
                <option value="claude">Claude API (via proxy)</option>
                <option value="openai">OpenAI-Compatible (direct or proxy)</option>
                <option value="local">Local GGUF on WebGPU</option>
            </select>
        </div>

        @if (_llmBackend == "claude")
        {
            <div class="vc-setting-group">
                <label>Proxy URL:</label>
                <input type="text" @bind="_proxyUrl" placeholder="https://your-server.com:port/api/claude" class="vc-input" />
            </div>
            <div class="vc-setting-group">
                <label>API Key:</label>
                <input type="password" @bind="_apiKey" placeholder="sk-ant-... (optional — proxy may have its own)" class="vc-input" />
                <span style="font-size: 0.8rem; color: #888;">Stored in memory only. Passed to proxy which relays to Anthropic.</span>
            </div>
            <div class="vc-setting-group">
                <label>Model:</label>
                <input type="text" @bind="_claudeModel" placeholder="claude-sonnet-4-20250514" class="vc-input" />
            </div>
        }
        else if (_llmBackend == "openai")
        {
            <div class="vc-setting-group">
                <label>Endpoint:</label>
                <input type="text" @bind="_openAiEndpoint" placeholder="http://localhost:11434/v1/chat/completions (Ollama, LM Studio, vLLM, OpenAI...)" class="vc-input vc-input-wide" />
            </div>
            <div class="vc-setting-group">
                <label>API Key:</label>
                <input type="password" @bind="_openAiKey" placeholder="(optional — Ollama doesn't need one)" class="vc-input" />
            </div>
            <div class="vc-setting-group">
                <label>Model:</label>
                <input type="text" @bind="_openAiModel" placeholder="llama3, gpt-4o, mistral, phi3..." class="vc-input" />
            </div>
        }
        else if (_llmBackend == "local")
        {
            <div class="vc-setting-group">
                <label>Model:</label>
                <select @bind="_localModel" class="vc-select">
                    <option value="">(none loaded)</option>
                    @foreach (var m in _localModels)
                    {
                        <option value="@m">@m</option>
                    }
                </select>
                <span style="font-size: 0.8rem; color: #888;">Load a GGUF model on the Models page first. Runs entirely on your GPU — no server, no API key.</span>
            </div>
            <div class="vc-setting-group">
                <label>Status:</label>
                <span style="color: @(_localModelReady ? "#2e7d32" : "#d32f2f");">
                    @(_localModelReady ? "Ready" : "No model loaded")
                </span>
            </div>
        }

        <div class="vc-setting-group">
            <label>TTS Voice:</label>
            <select @bind="_selectedVoice" class="vc-select">
                @if (_availableVoices != null)
                {
                    @foreach (var voice in _availableVoices)
                    {
                        <option value="@voice">@voice</option>
                    }
                }
            </select>
        </div>

        <div class="vc-setting-group">
            <label>
                <input type="checkbox" @bind="_speakResponses" /> Speak agent responses aloud
            </label>
        </div>
    </div>
</div>

<style>
    .vc-page {
        max-width: 900px;
        margin: 0 auto;
        padding: 1rem;
    }
    .vc-header {
        margin-bottom: 1rem;
    }
    .vc-title {
        font-size: 1.8rem;
        margin: 0 0 0.5rem 0;
    }
    .vc-description {
        color: #666;
        margin: 0;
    }
    .vc-transcript {
        background: #1a1a2e;
        color: #e0e0e0;
        border-radius: 8px;
        padding: 1rem;
        min-height: 300px;
        max-height: 500px;
        overflow-y: auto;
        font-family: 'Cascadia Code', 'Consolas', monospace;
        font-size: 0.9rem;
        margin-bottom: 1rem;
    }
    .vc-empty {
        color: #888;
        text-align: center;
        padding: 3rem 1rem;
    }
    .vc-entry {
        margin-bottom: 0.75rem;
        line-height: 1.5;
    }
    .vc-speaker {
        font-weight: bold;
        margin-right: 0.5rem;
    }
    .vc-time {
        color: #666;
        font-size: 0.8rem;
        margin-right: 0.5rem;
    }
    .vc-entry-user .vc-speaker { color: #64b5f6; }
    .vc-entry-agent .vc-speaker { color: #81c784; }
    .vc-entry-system .vc-speaker { color: #ffb74d; }
    .vc-thinking {
        color: #888;
        font-style: italic;
    }
    .vc-controls {
        display: flex;
        gap: 1rem;
        align-items: center;
        margin-bottom: 1rem;
        flex-wrap: wrap;
    }
    .vc-buttons {
        display: flex;
        gap: 0.5rem;
    }
    .vc-btn {
        padding: 0.5rem 1.25rem;
        border: none;
        border-radius: 6px;
        font-size: 0.95rem;
        cursor: pointer;
        font-weight: 600;
    }
    .vc-btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }
    .vc-btn-start {
        background: #2e7d32;
        color: white;
    }
    .vc-btn-stop {
        background: #d32f2f;
        color: white;
    }
    .vc-btn-clear {
        background: #555;
        color: white;
    }
    .vc-settings {
        background: #f5f5f5;
        border-radius: 8px;
        padding: 1rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }
    .vc-setting-group {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
    }
    .vc-setting-group > label {
        font-weight: 600;
        min-width: 100px;
        font-size: 0.9rem;
    }
    .vc-select, .vc-input {
        padding: 0.3rem 0.5rem;
        border: 1px solid #ccc;
        border-radius: 4px;
        font-size: 0.9rem;
    }
    .vc-input {
        width: 300px;
    }
    .vc-input-wide {
        width: 500px;
    }
    .vc-agent-list {
        display: flex;
        gap: 0.4rem;
    }
    .vc-agent-btn {
        padding: 0.3rem 0.75rem;
        border: 2px solid #ccc;
        border-radius: 6px;
        background: white;
        cursor: pointer;
        font-size: 0.85rem;
    }
    .vc-agent-btn.active {
        border-color: #2e7d32;
        background: #e8f5e9;
        font-weight: 600;
    }
</style>
