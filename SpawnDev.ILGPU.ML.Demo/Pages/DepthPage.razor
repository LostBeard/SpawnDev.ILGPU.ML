@page "/depth"

<PageTitle>Depth Estimation — SpawnDev.ILGPU.ML</PageTitle>

<DemoLayout Title="Depth Estimation"
            Description="Estimate monocular depth using Depth Anything V2 Small (26M params). Upload an image to generate a color-mapped depth map."
            AvailableBackends="@_backends"
            SelectedBackend="@_selectedBackend"
            SelectedBackendChanged="@((v) => _selectedBackend = v)"
            OnBackendChange="@HandleBackendChange"
            InferenceTimeMs="@_inferenceMs"
            IsRunning="@_isRunning"
            ShowModelProgress="true"
            ModelName="Depth Anything V2 Small"
            IsModelLoading="@_isModelLoading"
            IsModelLoaded="@_isModelLoaded"
            ModelProgressPercent="@_modelProgress"
            ModelSizeMB="95">

    <div class="depth-controls">
        <label class="palette-label">Color palette:</label>
        <select class="palette-select" @bind="_colorPalette" @bind:after="RecolorDepth">
            <option value="plasma">Plasma</option>
            <option value="viridis">Viridis</option>
            <option value="inferno">Inferno</option>
            <option value="grayscale">Grayscale</option>
        </select>
    </div>

    @if (_depthImageUrl != null && _imageDataUrl != null)
    {
        <BeforeAfterSlider BeforeImageUrl="@_imageDataUrl"
                           AfterImageUrl="@_depthImageUrl"
                           BeforeLabel="Original"
                           AfterLabel="@($"Depth ({_colorPalette})")" />

        <div class="depth-stats">
            <span class="depth-stat">Min depth: @_minDepth.ToString("F3")</span>
            <span class="depth-stat">Max depth: @_maxDepth.ToString("F3")</span>
            <span class="depth-stat">Range: @((_maxDepth - _minDepth).ToString("F3"))</span>
        </div>

        <div class="result-actions">
            <button class="action-btn download-btn" @onclick="DownloadResult">
                Download Depth Map
            </button>
            <button class="action-btn clear-btn" @onclick="ClearResult">
                Try Another Image
            </button>
        </div>
    }
    else
    {
        <ImageDropZone @bind-ImageDataUrl="_imageDataUrl"
                       OnImageLoaded="@HandleImageLoaded"
                       SampleImages="@_samples" />
    }

    @if (_imageDataUrl != null && _depthImageUrl == null && _isModelLoaded && !_isRunning)
    {
        <button class="run-btn" @onclick="RunDepthEstimation">Estimate Depth</button>
    }

    @if (!string.IsNullOrEmpty(_statusMessage))
    {
        <div class="status-message">@_statusMessage</div>
    }

    <PrivacyBadge />

</DemoLayout>

<style>
    .depth-controls {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 1rem;
    }

    .palette-label {
        color: #64748b;
        font-size: 0.85rem;
    }

    .palette-select {
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 6px;
        color: #e2e8f0;
        padding: 0.3rem 0.5rem;
        font-size: 0.85rem;
    }

    .palette-select option {
        background: #1e293b;
    }

    .depth-stats {
        display: flex;
        gap: 1.5rem;
        margin-top: 0.75rem;
    }

    .depth-stat {
        color: #94a3b8;
        font-size: 0.8rem;
        font-family: 'JetBrains Mono', 'Consolas', monospace;
    }

    .run-btn {
        margin-top: 1rem;
        padding: 0.6rem 1.5rem;
        border-radius: 8px;
        border: none;
        background: linear-gradient(135deg, #3b82f6 0%, #8b5cf6 100%);
        color: white;
        font-weight: 600;
        font-size: 0.95rem;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .run-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(59, 130, 246, 0.3);
    }

    .result-actions { display: flex; gap: 0.5rem; margin-top: 1rem; }
    .action-btn { padding: 0.5rem 1rem; border-radius: 8px; font-size: 0.85rem; font-weight: 600; cursor: pointer; transition: all 0.15s ease; }
    .download-btn { border: 1px solid rgba(52,211,153,0.3); background: rgba(52,211,153,0.1); color: #6ee7b7; }
    .download-btn:hover { background: rgba(52,211,153,0.2); transform: translateY(-1px); }
    .clear-btn { border: 1px solid rgba(255,255,255,0.1); background: rgba(255,255,255,0.05); color: #94a3b8; }
    .clear-btn:hover { background: rgba(255,255,255,0.1); }

    .status-message {
        margin-top: 0.75rem;
        color: #94a3b8;
        font-size: 0.85rem;
        font-style: italic;
    }
</style>

@code {
    // UI state — methods in DepthPage.razor.cs
    private string _selectedBackend = "WebGPU";
    private string? _imageDataUrl;
    private string? _depthImageUrl;
    private string _colorPalette = "plasma";
    private bool _isRunning;
    private bool _isModelLoading;
    private bool _isModelLoaded;
    private double _modelProgress;
    private double _inferenceMs;
    private float _minDepth;
    private float _maxDepth;
    private float[]? _depthMap;
    private int _depthWidth;
    private int _depthHeight;
    private string? _statusMessage;

    private List<BackendSelector.BackendInfo> _backends = new()
    {
        new() { Id = "WebGPU", DisplayName = "WebGPU" },
        new() { Id = "WebGL", DisplayName = "WebGL" },
        new() { Id = "Wasm", DisplayName = "Wasm (CPU)" },
    };

    private List<ImageDropZone.SampleImage> _samples = new()
    {
        new() { Label = "Street", Url = "samples/street.jpg" },
        new() { Label = "Room", Url = "samples/room.jpg" },
        new() { Label = "Landscape", Url = "samples/landscape.jpg" },
    };

    private void RecolorDepth()
    {
        if (_depthMap == null) return;
        var rgba = SpawnDev.ILGPU.ML.Preprocessing.DepthColorMaps.ApplyColorMap(_depthMap, _depthWidth, _depthHeight, _colorPalette);
        var pngBytes = SpawnDev.ILGPU.ML.Preprocessing.PngEncoder.Encode(rgba, _depthWidth, _depthHeight);
        _depthImageUrl = $"data:image/png;base64,{Convert.ToBase64String(pngBytes)}";
        StateHasChanged();
    }
}
