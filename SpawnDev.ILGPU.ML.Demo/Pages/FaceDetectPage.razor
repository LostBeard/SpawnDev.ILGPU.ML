@page "/face"
@using SpawnDev.BlazorJS
@using SpawnDev.ILGPU.ML
@using SpawnDev.ILGPU.ML.Hub
@using SpawnDev.ILGPU.ML.Pipelines
@implements IDisposable

<PageTitle>Face Detection — SpawnDev.ILGPU.ML</PageTitle>

<DemoLayout Title="Face Detection &amp; Landmarks"
            Description="Real-time face detection with landmark points. BlazeFace is only ~0.5MB — loads instantly."
            AvailableBackends="@_backends"
            SelectedBackend="@_selectedBackend"
            SelectedBackendChanged="@((v) => _selectedBackend = v)"
            OnBackendChange="@HandleBackendChange"
            InferenceTimeMs="@_inferenceMs"
            IsRunning="@_isRunning"
            ShowFps="true"
            ShowModelProgress="true"
            ModelName="BlazeFace"
            IsModelLoading="@_isModelLoading"
            IsModelLoaded="@_isModelLoaded"
            ModelProgressPercent="@_modelProgress"
            ModelSizeMB="0.5">

    <div class="face-controls">
        <div class="control-group">
            <label>Show:</label>
            <label class="checkbox-label"><input type="checkbox" @bind="_showBoxes" /> Boxes</label>
            <label class="checkbox-label"><input type="checkbox" @bind="_showLandmarks" /> Landmarks</label>
            <label class="checkbox-label"><input type="checkbox" @bind="_showConfidence" /> Confidence</label>
        </div>
        <span class="face-count">Faces: @_faceCount</span>
    </div>

    <div class="face-viewport">
        <WebcamCapture OnFrameCaptured="@HandleFrame"
                       AutoCapture="@_isModelLoaded"
                       CaptureIntervalMs="33"
                       ShowCaptureButton="true"
                       Width="640" Height="480" />

        @if (_faces != null && _faces.Count > 0)
        {
            <svg class="face-overlay" viewBox="0 0 640 480" preserveAspectRatio="xMidYMid meet">
                @foreach (var face in _faces)
                {
                    @if (_showBoxes)
                    {
                        <rect x="@face.X" y="@face.Y" width="@face.Width" height="@face.Height"
                              fill="none" stroke="#3b82f6" stroke-width="2" rx="4" />
                    }
                    @if (_showConfidence)
                    {
                        @((MarkupString)$"<text x=\"{face.X}\" y=\"{face.Y - 6}\" fill=\"#3b82f6\" font-size=\"12\" font-weight=\"600\">{(face.Confidence * 100):F0}%</text>")
                    }
                    @if (_showLandmarks)
                    {
                        @foreach (var (lx, ly) in face.Landmarks)
                        {
                            <circle cx="@lx" cy="@ly" r="3" fill="#34d399" stroke="#0f172a" stroke-width="1" />
                        }
                    }
                }
            </svg>
        }
    </div>

    @if (!_isModelLoaded && !_isModelLoading)
    {
        <div class="model-needed">
            BlazeFace model (~0.5MB) loads almost instantly. Face detection will be enabled once the model is deployed.
        </div>
    }

    <PrivacyBadge />

</DemoLayout>

<style>
    .face-controls { display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem; flex-wrap: wrap; }
    .control-group { display: flex; align-items: center; gap: 0.75rem; }
    .control-group label:first-child { color: #64748b; font-size: 0.85rem; }
    .checkbox-label { display: flex; align-items: center; gap: 0.3rem; color: #94a3b8; font-size: 0.82rem; cursor: pointer; }
    .checkbox-label input { accent-color: #8b5cf6; }
    .face-count { margin-left: auto; color: #38bdf8; font-size: 0.9rem; font-weight: 700; font-family: monospace; }

    .face-viewport { position: relative; border-radius: 10px; overflow: hidden; }
    .face-overlay { position: absolute; inset: 0; width: 100%; height: 100%; pointer-events: none; z-index: 2; }

    .model-needed { margin-top: 1rem; padding: 0.75rem 1rem; background: rgba(245,158,11,0.08); border: 1px solid rgba(245,158,11,0.2); border-radius: 8px; color: #fbbf24; font-size: 0.85rem; }
</style>

@code {
    private string _selectedBackend = "WebGPU";
    private bool _showBoxes = true, _showLandmarks = true, _showConfidence = true;
    private int _faceCount;
    private List<FaceDetection>? _faces;
    private bool _isRunning, _isModelLoading, _isModelLoaded;
    private double _modelProgress, _inferenceMs;
    private bool _processingFrame;

    private List<BackendSelector.BackendInfo> _backends = new()
    {
        new() { Id = "WebGPU", DisplayName = "WebGPU" },
        new() { Id = "WebGL", DisplayName = "WebGL" },
        new() { Id = "Wasm", DisplayName = "Wasm (CPU)" },
    };

    [Inject] BlazorJS.BlazorJSRuntime JS { get; set; } = default!;

    private global::ILGPU.Runtime.Accelerator? _accelerator;
    private global::ILGPU.Context? _context;
    private Pipelines.FaceDetectionPipeline? _pipeline;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await LoadModelAsync();
    }

    private async Task LoadModelAsync()
    {
        try
        {
            _isModelLoading = true;
            StateHasChanged();

            if (_context == null)
            {
                var builder = MLContext.Create();
                await builder.AllAcceleratorsAsync();
                _context = builder.ToContext();
            }

            _accelerator = await _context.CreatePreferredAcceleratorAsync();
            if (_accelerator == null) { _isModelLoading = false; StateHasChanged(); return; }

            using var hub = new Hub.ModelHub(JS);
            var modelBytes = await hub.LoadAsync(Hub.ModelHub.KnownModels.BlazeFace, "model.tflite");
            var session = InferenceSession.CreateFromFile(_accelerator, modelBytes);
            _pipeline = new Pipelines.FaceDetectionPipeline(session, _accelerator);

            _isModelLoaded = true;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Face] Error: {ex.Message}");
        }
        finally
        {
            _isModelLoading = false;
            StateHasChanged();
        }
    }

    private Task HandleBackendChange(string backend) => LoadModelAsync();

    private async Task HandleFrame(byte[] frameBytes)
    {
        if (_pipeline == null || _processingFrame) return;
        _processingFrame = true;
        try
        {
            var rgbaPixels = new int[frameBytes.Length / 4];
            Buffer.BlockCopy(frameBytes, 0, rgbaPixels, 0, frameBytes.Length);

            _isRunning = true;
            var result = await _pipeline.DetectAsync(rgbaPixels, 640, 480);
            _inferenceMs = result.InferenceTimeMs;
            _faceCount = result.FaceCount;

            _faces = result.Faces.Select(f => new FaceDetection
            {
                X = f.X,
                Y = f.Y,
                Width = f.Width,
                Height = f.Height,
                Confidence = f.Confidence,
                Landmarks = f.Landmarks,
            }).ToList();

            _isRunning = false;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Face] Frame error: {ex.Message}");
            _isRunning = false;
        }
        finally
        {
            _processingFrame = false;
        }
    }

    public void Dispose()
    {
        _pipeline?.Dispose();
        _accelerator?.Dispose();
        _context?.Dispose();
    }

    private class FaceDetection
    {
        public float X { get; set; }
        public float Y { get; set; }
        public float Width { get; set; }
        public float Height { get; set; }
        public float Confidence { get; set; }
        public List<(float X, float Y)> Landmarks { get; set; } = new();
    }
}
