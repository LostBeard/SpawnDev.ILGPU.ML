        </div>
        <div class="roadmap-item active">
            <div class="roadmap-status">Active</div>
            <div class="roadmap-label">Depth estimation, object detection, pose estimation</div>
        </div>
        <div class="roadmap-item active">
            <div class="roadmap-status">Active</div>
            <div class="roadmap-label">HuggingFace Hub integration + OPFS caching</div>
        </div>
        <div class="roadmap-item planned">
            <div class="roadmap-status">Planned</div>
