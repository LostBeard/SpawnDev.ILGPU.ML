@page "/benchmark"

<PageTitle>Benchmark — SpawnDev.ILGPU.ML</PageTitle>

<div class="bench-page">
    <div class="bench-header">
        <h1 class="bench-title">
            <span class="bench-icon">&#x26A1;</span> Backend Benchmark
        </h1>
        <p class="bench-desc">
            How fast is YOUR device? Run standardized ML benchmarks across all available backends.
            Same model, same data, same code — different GPU paths. Share your results.
        </p>
    </div>

    @if (!_isRunning && _results.Count == 0)
    {
        <div class="bench-start-section">
            <div class="bench-test-selector">
                <h3>Select Tests</h3>
                <label class="bench-check"><input type="checkbox" @bind="_runClassification" /> Image Classification (SqueezeNet, 4.8MB)</label>
                <label class="bench-check"><input type="checkbox" @bind="_runStyleTransfer" /> Style Transfer (Mosaic, 6.5MB)</label>
                <label class="bench-check"><input type="checkbox" @bind="_runSuperRes" /> Super Resolution (ESPCN, 0.2MB)</label>
            </div>

            <div class="bench-backend-selector">
                <h3>Backends</h3>
                <label class="bench-check"><input type="checkbox" @bind="_benchWebGPU" /> WebGPU</label>
                <label class="bench-check"><input type="checkbox" @bind="_benchWebGL" /> WebGL</label>
                <label class="bench-check"><input type="checkbox" @bind="_benchWasm" /> Wasm (CPU)</label>
            </div>

            <button class="bench-run-btn" @onclick="RunBenchmarks">
                <span class="btn-icon">&#x1F3C1;</span> Run Benchmarks
            </button>
        </div>
    }

    @if (_isRunning)
    {
        <div class="bench-progress">
            <div class="bench-current-test">@_currentTest</div>
            <div class="bench-progress-bar">
                <div class="bench-progress-fill" style="width: @_progressPercent%;"></div>
            </div>
            <span class="bench-progress-text">@_completedTests / @_totalTests tests</span>
        </div>
    }

    @if (_results.Count > 0)
    {
        <div class="bench-results-section">
            <h2 class="results-title">Results</h2>

            @foreach (var group in _results.GroupBy(r => r.TestName))
            {
                <div class="result-group">
                    <h3 class="group-title">@group.Key</h3>
                    <div class="result-bars">
                        @{ var sorted = group.OrderBy(r => r.InferenceMs).ToList(); }
                        @{ var maxMs = sorted.Max(r => r.InferenceMs); }
                        @{ int rank = 0; }
                        @foreach (var r in sorted)
                        {
                            rank++;
                            <div class="result-bar-row">
                                <span class="result-medal">@(rank switch { 1 => "&#x1F947;", 2 => "&#x1F948;", 3 => "&#x1F949;", _ => "" })</span>
                                <span class="result-backend">@r.BackendName</span>
                                <div class="result-bar-track">
                                    <div class="result-bar-fill @(rank == 1 ? "fastest" : "")"
                                         style="width: @(r.InferenceMs / maxMs * 100)%;"></div>
                                </div>
                                <span class="result-time">@r.InferenceMs.ToString("F1") ms</span>
                                @if (rank > 1)
                                {
                                    <span class="result-ratio">@((r.InferenceMs / sorted[0].InferenceMs).ToString("F1"))x</span>
                                }
                            </div>
                        }
                    </div>
                </div>
            }

            <div class="bench-actions">
                <button class="bench-copy-btn" @onclick="CopyResults">
                    &#x1F4CB; Copy Results
                </button>
                <button class="bench-tweet-btn" @onclick="CopyOneLiner">
                    &#x1F426; Copy One-Liner
                </button>
                <button class="bench-rerun-btn" @onclick="ClearResults">
                    &#x1F504; Run Again
                </button>
            </div>

            @if (_copied)
            {
                <div class="copied-toast">Copied to clipboard!</div>
            }
        </div>

        <div class="bench-device-info">
            <h3>Device Info</h3>
            <div class="device-row"><span>User Agent:</span><span class="device-value">@_userAgent</span></div>
            <div class="device-row"><span>GPU:</span><span class="device-value">@(_gpuName ?? "Unknown")</span></div>
            <div class="device-row"><span>Date:</span><span class="device-value">@DateTime.UtcNow.ToString("yyyy-MM-dd HH:mm") UTC</span></div>
        </div>
    }

    <PrivacyBadge />
</div>

<style>
    .bench-page { max-width: 800px; margin: 0 auto; }
    .bench-header { margin-bottom: 2rem; }
    .bench-title { font-size: 1.8rem; font-weight: 800; color: #f1f5f9; display: flex; align-items: center; gap: 0.5rem; }
    .bench-icon { font-size: 1.5rem; }
    .bench-desc { color: #64748b; font-size: 0.95rem; line-height: 1.6; margin-top: 0.5rem; }

    .bench-start-section { display: flex; flex-direction: column; gap: 1.5rem; }
    .bench-test-selector, .bench-backend-selector { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; padding: 1.25rem; }
    .bench-test-selector h3, .bench-backend-selector h3 { color: #f1f5f9; font-size: 1rem; margin-bottom: 0.75rem; }
    .bench-check { display: flex; align-items: center; gap: 0.5rem; color: #cbd5e1; font-size: 0.9rem; margin-bottom: 0.4rem; cursor: pointer; }
    .bench-check input { accent-color: #8b5cf6; width: 16px; height: 16px; }

    .bench-run-btn {
        display: flex; align-items: center; justify-content: center; gap: 0.5rem;
        padding: 0.8rem 2rem; border-radius: 10px; border: none;
        background: linear-gradient(135deg, #3b82f6, #8b5cf6);
        color: white; font-size: 1.1rem; font-weight: 700; cursor: pointer;
        transition: all 0.2s; width: fit-content; align-self: center;
    }
    .bench-run-btn:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(59,130,246,0.4); }
    .btn-icon { font-size: 1.3rem; }

    .bench-progress { margin: 2rem 0; text-align: center; }
    .bench-current-test { color: #38bdf8; font-size: 1rem; font-weight: 600; margin-bottom: 0.5rem; animation: pulse 1.5s ease-in-out infinite; }
    .bench-progress-bar { height: 10px; background: rgba(255,255,255,0.06); border-radius: 5px; overflow: hidden; }
    .bench-progress-fill { height: 100%; background: linear-gradient(90deg, #3b82f6, #8b5cf6); border-radius: 5px; transition: width 0.3s; }
    .bench-progress-text { color: #94a3b8; font-size: 0.85rem; margin-top: 0.3rem; display: block; }

    .bench-results-section { margin: 2rem 0; }
    .results-title { color: #f1f5f9; font-size: 1.3rem; margin-bottom: 1rem; }

    .result-group { margin-bottom: 1.5rem; }
    .group-title { color: #cbd5e1; font-size: 1rem; margin-bottom: 0.5rem; }

    .result-bars { display: flex; flex-direction: column; gap: 0.5rem; }
    .result-bar-row { display: flex; align-items: center; gap: 0.5rem; }
    .result-medal { min-width: 24px; font-size: 1.1rem; text-align: center; }
    .result-backend { min-width: 70px; color: #cbd5e1; font-size: 0.85rem; font-weight: 600; }
    .result-bar-track { flex: 1; height: 28px; background: rgba(255,255,255,0.04); border-radius: 6px; overflow: hidden; }
    .result-bar-fill { height: 100%; background: linear-gradient(90deg, #64748b, #94a3b8); border-radius: 6px; transition: width 0.8s cubic-bezier(0.4, 0, 0.2, 1); }
    .result-bar-fill.fastest { background: linear-gradient(90deg, #3b82f6, #8b5cf6); }
    .result-time { min-width: 70px; text-align: right; color: #e2e8f0; font-size: 0.85rem; font-family: 'JetBrains Mono', monospace; font-weight: 700; }
    .result-ratio { min-width: 40px; text-align: right; color: #64748b; font-size: 0.75rem; font-family: monospace; }

    .bench-actions { display: flex; gap: 0.5rem; margin-top: 1.5rem; justify-content: center; flex-wrap: wrap; }
    .bench-copy-btn, .bench-tweet-btn, .bench-rerun-btn {
        display: flex; align-items: center; gap: 0.3rem;
        padding: 0.5rem 1rem; border-radius: 8px; font-size: 0.85rem; font-weight: 600;
        cursor: pointer; transition: all 0.15s;
    }
    .bench-copy-btn { border: 1px solid rgba(52,211,153,0.3); background: rgba(52,211,153,0.1); color: #6ee7b7; }
    .bench-copy-btn:hover { background: rgba(52,211,153,0.2); }
    .bench-tweet-btn { border: 1px solid rgba(56,189,248,0.3); background: rgba(56,189,248,0.1); color: #7dd3fc; }
    .bench-tweet-btn:hover { background: rgba(56,189,248,0.2); }
    .bench-rerun-btn { border: 1px solid rgba(255,255,255,0.1); background: rgba(255,255,255,0.05); color: #94a3b8; }
    .bench-rerun-btn:hover { background: rgba(255,255,255,0.1); }

    .copied-toast { text-align: center; color: #34d399; font-size: 0.85rem; margin-top: 0.5rem; animation: fadeout 2s forwards; }

    .bench-device-info { margin-top: 2rem; padding: 1rem; background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.06); border-radius: 8px; }
    .bench-device-info h3 { color: #94a3b8; font-size: 0.85rem; margin-bottom: 0.5rem; }
    .device-row { display: flex; justify-content: space-between; padding: 0.2rem 0; }
    .device-row span:first-child { color: #64748b; font-size: 0.8rem; }
    .device-value { color: #94a3b8; font-size: 0.8rem; font-family: monospace; max-width: 400px; overflow: hidden; text-overflow: ellipsis; }

    @@keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.5; } }
    @@keyframes fadeout { 0% { opacity: 1; } 80% { opacity: 1; } 100% { opacity: 0; } }
</style>

@code {
    private bool _runClassification = true, _runStyleTransfer = true, _runSuperRes = true;
    private bool _benchWebGPU = true, _benchWebGL, _benchWasm;
    private bool _isRunning, _copied;
    private string _currentTest = "";
    private int _completedTests, _totalTests;
    private float _progressPercent;
    private string? _userAgent, _gpuName;
    private List<BenchResult> _results = new();

    private Task RunBenchmarks()
    {
        // TODO: Wire to actual benchmark runner
        _isRunning = true;
        _currentTest = "Initializing...";
        StateHasChanged();
        return Task.CompletedTask;
    }

    private Task CopyResults()
    {
        _copied = true;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private Task CopyOneLiner()
    {
        _copied = true;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private void ClearResults()
    {
        _results.Clear();
        _completedTests = 0;
        _copied = false;
        StateHasChanged();
    }

    private class BenchResult
    {
        public string TestName { get; set; } = "";
        public string BackendName { get; set; } = "";
        public double InferenceMs { get; set; }
        public double ModelLoadMs { get; set; }
    }
}
