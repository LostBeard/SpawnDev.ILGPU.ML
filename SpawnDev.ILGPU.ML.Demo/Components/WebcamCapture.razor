@using SpawnDev.BlazorJS
@using SpawnDev.BlazorJS.JSObjects
@inject BlazorJSRuntime JS
@implements IAsyncDisposable

<div class="webcam-container">
    @if (!_isStreaming)
    {
        <button class="webcam-start-btn" @onclick="StartCamera">
            <span class="webcam-btn-icon">&#x1F4F7;</span> Enable Camera
        </button>
    }
    else
    {
        <div class="webcam-live">
            <video @ref="_videoRef" autoplay playsinline muted class="webcam-video"></video>
            @if (ShowCaptureButton)
            {
                <button class="webcam-capture-btn" @onclick="CaptureFrame" title="Capture frame">
                    &#x23FA;
                </button>
            }
            <button class="webcam-stop-btn" @onclick="StopCamera" title="Stop camera">
                &#x23F9;
            </button>
        </div>
    }
</div>

@code {
    private ElementReference _videoRef;
    private bool _isStreaming;
    private MediaStream? _stream;

    [Parameter] public EventCallback<byte[]> OnFrameCaptured { get; set; }
    [Parameter] public EventCallback<string> OnFrameDataUrl { get; set; }
    [Parameter] public bool ShowCaptureButton { get; set; } = true;
    [Parameter] public bool AutoCapture { get; set; }
    [Parameter] public int CaptureIntervalMs { get; set; } = 100;
    [Parameter] public int Width { get; set; } = 640;
    [Parameter] public int Height { get; set; } = 480;

    private async Task StartCamera()
    {
        try
        {
            using var navigator = JS.Get<Navigator>("navigator");
            using var mediaDevices = navigator.MediaDevices;
            _stream = await mediaDevices.GetUserMedia(new MediaStreamConstraints
            {
                Video = new MediaTrackConstraints
                {
                    Width = new ConstrainULongRange { Ideal = (uint)Width },
                    Height = new ConstrainULongRange { Ideal = (uint)Height }
                },
                Audio = false
            });

            // Attach stream to video element
            using var videoEl = new HTMLVideoElement(_videoRef);
            videoEl.SrcObject = _stream;

            _isStreaming = true;
            StateHasChanged();

            if (AutoCapture)
                _ = AutoCaptureLoop();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[WebcamCapture] Camera error: {ex.Message}");
        }
    }

    private async Task StopCamera()
    {
        _isStreaming = false;
        if (_stream != null)
        {
            var tracks = _stream.GetTracks();
            foreach (var track in tracks)
            {
                track.Stop();
                track.Dispose();
            }
            _stream.Dispose();
            _stream = null;
        }
    }

    public async Task CaptureFrame()
    {
        if (!_isStreaming) return;

        try
        {
            using var videoEl = new HTMLVideoElement(_videoRef);
            int w = (int)videoEl.VideoWidth;
            int h = (int)videoEl.VideoHeight;
            if (w == 0 || h == 0) return;

            using var canvas = new HTMLCanvasElement();
            canvas.Width = w;
            canvas.Height = h;
            using var ctx = canvas.Get2DContext();
            ctx.DrawImage(videoEl, 0, 0, w, h);

            // Get data URL for display
            var dataUrl = canvas.ToDataURL("image/jpeg", 0.85f);
            if (OnFrameDataUrl.HasDelegate)
                await OnFrameDataUrl.InvokeAsync(dataUrl);

            // Get raw bytes for inference
            if (OnFrameCaptured.HasDelegate)
            {
                using var imageData = ctx.GetImageData(0, 0, w, h);
                using var data = imageData.Data;
                var rgbaBytes = data.ReadBytes();
                await OnFrameCaptured.InvokeAsync(rgbaBytes);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[WebcamCapture] Capture error: {ex.Message}");
        }
    }

    private async Task AutoCaptureLoop()
    {
        while (_isStreaming)
        {
            await CaptureFrame();
            await Task.Delay(CaptureIntervalMs);
        }
    }

    public async ValueTask DisposeAsync()
    {
        _isStreaming = false;
        await StopCamera();
    }
}

<style>
    .webcam-container {
        position: relative;
        border-radius: 10px;
        overflow: hidden;
        background: rgba(0, 0, 0, 0.3);
        min-height: 200px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .webcam-start-btn {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.5rem;
        border-radius: 8px;
        border: 1px solid rgba(255, 255, 255, 0.15);
        background: rgba(255, 255, 255, 0.06);
        color: #e2e8f0;
        font-size: 0.95rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .webcam-start-btn:hover {
        background: rgba(139, 92, 246, 0.15);
        border-color: rgba(139, 92, 246, 0.3);
    }

    .webcam-btn-icon { font-size: 1.2rem; }

    .webcam-live { position: relative; width: 100%; }

    .webcam-video { width: 100%; display: block; border-radius: 10px; }

    .webcam-capture-btn,
    .webcam-stop-btn {
        position: absolute;
        bottom: 0.75rem;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        border: none;
        color: white;
        font-size: 1rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.15s ease;
    }

    .webcam-capture-btn { right: 3.5rem; background: rgba(59, 130, 246, 0.8); }
    .webcam-capture-btn:hover { background: #3b82f6; transform: scale(1.1); }

    .webcam-stop-btn { right: 0.75rem; background: rgba(239, 68, 68, 0.8); }
    .webcam-stop-btn:hover { background: #ef4444; transform: scale(1.1); }
</style>
