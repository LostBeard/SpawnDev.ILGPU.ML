<div class="demo-page">
    <div class="demo-header">
        <h1 class="demo-title">@Title</h1>
        @if (!string.IsNullOrEmpty(Description))
        {
            <p class="demo-description">@Description</p>
        }
    </div>

    <div class="demo-toolbar">
        <BackendSelector AvailableBackends="@AvailableBackends"
                         SelectedBackend="@SelectedBackend"
                         SelectedBackendChanged="@SelectedBackendChanged"
                         OnBackendChange="@OnBackendChange"
                         DeviceName="@DeviceName" />

        <InferenceTimer InferenceTimeMs="@InferenceTimeMs"
                        IsRunning="@IsRunning"
                        ShowFps="@ShowFps"
                        BackendName="@SelectedBackend"
                        ShowBackendName="false" />

        <PrivacyBadge />
    </div>

    @if (ShowModelProgress)
    {
        <div class="demo-model-progress">
            <ModelLoadProgress ModelName="@ModelName"
                               IsLoading="@IsModelLoading"
                               IsComplete="@IsModelLoaded"
                               ProgressPercent="@ModelProgressPercent"
                               TotalSizeMB="@ModelSizeMB" />
        </div>
    }

    <div class="demo-content">
        @ChildContent
    </div>
</div>

@code {
    [Parameter] public string Title { get; set; } = "Demo";
    [Parameter] public string? Description { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    // Backend
    [Parameter] public List<BackendSelector.BackendInfo> AvailableBackends { get; set; } = new();
    [Parameter] public string SelectedBackend { get; set; } = "";
    [Parameter] public EventCallback<string> SelectedBackendChanged { get; set; }
    [Parameter] public EventCallback<string> OnBackendChange { get; set; }
    [Parameter] public string? DeviceName { get; set; }

    // Timer
    [Parameter] public double InferenceTimeMs { get; set; }
    [Parameter] public bool IsRunning { get; set; }
    [Parameter] public bool ShowFps { get; set; }

    // Model loading
    [Parameter] public bool ShowModelProgress { get; set; }
    [Parameter] public string ModelName { get; set; } = "Model";
    [Parameter] public bool IsModelLoading { get; set; }
    [Parameter] public bool IsModelLoaded { get; set; }
    [Parameter] public double ModelProgressPercent { get; set; }
    [Parameter] public double ModelSizeMB { get; set; }
}

<style>
    .demo-page {
        max-width: 960px;
        margin: 0 auto;
    }

    .demo-header {
        margin-bottom: 1.25rem;
    }

    .demo-title {
        font-size: 1.6rem;
        font-weight: 700;
        color: #f1f5f9;
        margin-bottom: 0.25rem;
    }

    .demo-description {
        color: #64748b;
        font-size: 0.95rem;
        line-height: 1.5;
        margin: 0;
    }

    .demo-toolbar {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin-bottom: 1.25rem;
        padding: 0.6rem 0;
        border-top: 1px solid rgba(255, 255, 255, 0.06);
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }

    .demo-model-progress {
        margin-bottom: 1rem;
    }

    .demo-content {
        margin-top: 0.5rem;
    }
</style>
