@using Microsoft.JSInterop

<div class="bbox-container" style="position: relative; display: inline-block;">
    @ChildContent
    <svg class="bbox-svg" viewBox="0 0 @ImageWidth @ImageHeight"
         preserveAspectRatio="xMidYMid meet">
        @if (Detections?.Any() == true)
        {
            @foreach (var det in Detections.Where(d => d.Confidence >= ConfidenceThreshold))
            {
                var color = GetClassColor(det.ClassId);
                <rect x="@det.X" y="@det.Y" width="@det.Width" height="@det.Height"
                      fill="none" stroke="@color" stroke-width="@StrokeWidth" rx="3" />
                <rect x="@det.X" y="@(det.Y - 18)" width="@LabelWidth(det)" height="18"
                      fill="@color" rx="2" />
                @((MarkupString)$"<text x=\"{det.X + 4}\" y=\"{det.Y - 5}\" fill=\"white\" font-size=\"12\" font-weight=\"600\" font-family=\"sans-serif\">{det.Label} {(det.Confidence * 100):F0}%</text>")
            }
        }
    </svg>
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public List<Detection>? Detections { get; set; }
    [Parameter] public int ImageWidth { get; set; } = 640;
    [Parameter] public int ImageHeight { get; set; } = 480;
    [Parameter] public float ConfidenceThreshold { get; set; } = 0.5f;
    [Parameter] public int StrokeWidth { get; set; } = 2;

    private static readonly string[] ClassColors = new[]
    {
        "#3b82f6", "#ef4444", "#22c55e", "#f59e0b", "#8b5cf6",
        "#ec4899", "#14b8a6", "#f97316", "#06b6d4", "#84cc16",
        "#a855f7", "#e11d48", "#0ea5e9", "#d946ef", "#10b981",
        "#eab308", "#6366f1", "#f43f5e", "#2dd4bf", "#fb923c"
    };

    private string GetClassColor(int classId)
    {
        return ClassColors[classId % ClassColors.Length];
    }

    private int LabelWidth(Detection det)
    {
        return Math.Max(det.Label.Length * 8 + 40, 60);
    }

    public class Detection
    {
        public float X { get; set; }
        public float Y { get; set; }
        public float Width { get; set; }
        public float Height { get; set; }
        public string Label { get; set; } = "";
        public int ClassId { get; set; }
        public float Confidence { get; set; }
    }
}

<style>
    .bbox-container {
        width: 100%;
    }

    .bbox-svg {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
    }
</style>
